e-flex items-center gap-2.5 font-mono text-[11px] text-blue-brand uppercase tracking-[3px] mb-4","children":[["$","span",null,{"className":"block w-5 h-px bg-blue-brand"}],"Overview"]}],["$","p",null,{"className":"text-[16px] text-slate-600 leading-[1.9]","children":"ODIPA's Corporate Privacy Certification is a structured assessment of an organization's data practices against applicable privacy law and industry best practices. Unlike self-certification or checkbox compliance, ODIPA's process involves documentation review, staff training verification, breach response evaluation, and a structured interview with our assessment team. We benchmark against CCPA/CPRA, VCDPA, CPA, CTDPA, GLBA, BSA, PCI DSS, HIPAA, HITECH, NERC CIP, BIPA, FERPA, COPPA, SOC 2, NIST Privacy Framework, ISO 27001, GDPR, LGPD, PIPEDA, PIPL, and additional applicable state and international laws — covering financial services, healthcare, energy, education, technology, and all consumer-facing industries. Organizations that pass receive the ODIPA Trust Seal — a verifiable, annually renewed mark that signals genuine commitment to consumer privacy. Revenue from certifications directly funds ODIPA's free consumer programs."}]]}],["$","section",null,{"children":[["$","div",null,{"className":"inline-flex items-center gap-2.5 font-mono text-[11px] text-blue-brand uppercase tracking-[3px] mb-6","children":[["$","span",null,{"className":"block w-5 h-px bg-blue-brand"}],"What We Do"]}],["$","div",null,{"className":"grid grid-cols-1 sm:grid-cols-2 gap-4","children":[["$","div","Privacy Compliance Assessment",{"className":"bg-white rounded-xl border border-slate-200 p-6 hover:border-blue-brand/30 hover:shadow-sm transition-all","children":["$L4","$L5","$L6"]}],"$L7","$L8","$L9","$La","$Lb"]}]]}],"$Lc","$Ld","$Le","$Lf","$undefined","$L10"]}],"$L11"]}]]}],null,"$L12"]}],"loading":null,"isPartial":false}
