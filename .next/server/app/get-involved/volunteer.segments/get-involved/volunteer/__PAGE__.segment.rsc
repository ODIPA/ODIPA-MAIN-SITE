13:["$","section",null,{"children":[["$","div",null,{"className":"inline-flex items-center gap-2.5 font-mono text-[11px] text-blue-brand uppercase tracking-[3px] mb-6","children":[["$","span",null,{"className":"block w-5 h-px bg-blue-brand"}],"Common Questions"]}],["$","div",null,{"className":"space-y-4","children":[["$","div","Is volunteering fully remote?",{"className":"bg-white rounded-xl border border-slate-200 p-6","children":[["$","h3",null,{"className":"font-semibold text-[15px] text-navy mb-2","children":"Is volunteering fully remote?"}],["$","p",null,{"className":"text-[14px] text-slate-500 leading-[1.75]","children":"Yes — the vast majority of ODIPA volunteer work is remote and asynchronous. Some local volunteers may choose to help at in-person events in the Los Angeles area, but this is never required."}]]}],["$","div","How much time do I need to commit?",{"className":"bg-white rounded-xl border border-slate-200 p-6","children":[["$","h3",null,{"className":"font-semibold text-[15px] text-navy mb-2","children":"How much time do I need to commit?"}],["$","p",null,{"className":"text-[14px] text-slate-500 leading-[1.75]","children":"Most roles require 2–10 hours per engagement depending on the position. We work around your schedule and never pressure volunteers to overextend. Quality over quantity."}]]}],["$","div","Do I need privacy expertise to volunteer?",{"className":"bg-white rounded-xl border border-slate-200 p-6","children":[["$","h3",null,{"className":"font-semibold text-[15px] text-navy mb-2","children":"Do I need privacy expertise to volunteer?"}],["$","p",null,{"className":"text-[14px] text-slate-500 leading-[1.75]","children":"Not necessarily. While some roles require specific expertise (e.g., privacy law, software development), others need general skills like writing, translation, or community organizing. We train volunteers on privacy fundamentals."}]]}],["$","div","What credentials do I need to be a Certification Assessor?",{"className":"bg-white rounded-xl border border-slate-200 p-6","children":[["$","h3",null,{"className":"font-semibold text-[15px] text-navy mb-2","children":"What credentials do I need to be a Certification Assessor?"}],["$","p",null,{"className":"text-[14px] text-slate-500 leading-[1.75]","children":"Assessors must hold at least one active, recognized credential relevant to privacy or information security — such as CIPP/US, CIPP/E, CIPM, CISA, CISSP, QSA, CHPC, or CAMS. Credentials must be current and in good standing. Lapsed credentials require renewal before assessor assignments resume. If you are working toward a credential, apply now and we will match you to an assessor shadow role while you complete certification."}]]}],["$","div","Is there a background check?",{"className":"bg-white rounded-xl border border-slate-200 p-6","children":[["$","h3",null,{"className":"font-semibold text-[15px] text-navy mb-2","children":"Is there a background check?"}],["$","p",null,{"className":"text-[14px] text-slate-500 leading-[1.75]","children":"Volunteers in roles involving direct community outreach or certification program work may be asked to complete a basic background check. This will be communicated clearly during onboarding."}]]}],["$","div","Can I volunteer as part of a corporate social responsibility program?",{"className":"bg-white rounded-xl border border-slate-200 p-6","children":[["$","h3",null,{"className":"font-semibold text-[15px] text-navy mb-2","children":"Can I volunteer as part of a corporate social responsibility program?"}],["$","p",null,{"className":"text-[14px] text-slate-500 leading-[1.75]","children":"Yes. Many of our volunteers are supported by their employers through CSR programs. If your company offers volunteer time off (VTO) or skills-based volunteering programs, ODIPA qualifies. Contact volunteer@odipa.org for a corporate volunteer letter."}]]}]]}]]}]
