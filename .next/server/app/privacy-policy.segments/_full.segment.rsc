2a:["$","section",null,{"id":"data-security","className":"scroll-mt-24 mb-14","children":[["$","h2",null,{"className":"font-display text-[26px] font-bold text-navy mb-5 pb-3 border-b border-slate-200","children":"Data Security"}],["$","div",null,{"className":"space-y-4 text-[15px] text-slate-600 leading-[1.85]","children":[["$","p",null,{"children":"Our Site is hosted on Microsoft Azure Static Web Apps, which provides enterprise-grade infrastructure with TLS/HTTPS encryption in transit, DDoS protection, and global CDN delivery. We have configured the following security headers on all responses:"}],["$","div",null,{"className":"my-4 bg-navy rounded-xl p-5 font-mono text-[12px] space-y-1.5","children":[["$","div","Strict-Transport-Security",{"className":"flex gap-3","children":[["$","span",null,{"className":"text-gold-light flex-shrink-0","children":["Strict-Transport-Security",":"]}],["$","span",null,{"className":"text-white/60","children":"max-age=31536000; includeSubDomains"}]]}],["$","div","X-Content-Type-Options",{"className":"flex gap-3","children":[["$","span",null,{"className":"text-gold-light flex-shrink-0","children":["X-Content-Type-Options",":"]}],["$","span",null,{"className":"text-white/60","children":"nosniff"}]]}],["$","div","X-Frame-Options",{"className":"flex gap-3","children":[["$","span",null,{"className":"text-gold-light flex-shrink-0","children":["X-Frame-Options",":"]}],["$","span",null,{"className":"text-white/60","children":"DENY"}]]}],["$","div","X-XSS-Protection",{"className":"flex gap-3","children":[["$","span",null,{"className":"text-gold-light flex-shrink-0","children":["X-XSS-Protection",":"]}],["$","span",null,{"className":"text-white/60","children":"1; mode=block"}]]}],["$","div","Referrer-Policy",{"className":"flex gap-3","children":[["$","span",null,{"className":"text-gold-light flex-shrink-0","children":["Referrer-Policy",":"]}],["$","span",null,{"className":"text-white/60","children":"strict-origin-when-cross-origin"}]]}],["$","div","Permissions-Policy",{"className":"flex gap-3","children":[["$","span",null,{"className":"text-gold-light flex-shrink-0","children":["Permissions-Policy",":"]}],["$","span",null,{"className":"text-white/60","children":"camera=(), microphone=(), geolocation=()"}]]}]]}],["$","p",null,{"children":"Despite these measures, no transmission over the internet is 100% secure. We encourage you to take steps to protect your own data, including using a strong password manager, enabling two-factor authentication on sensitive accounts, and staying informed through ODIPA's free educational programs."}]]}]]}]
