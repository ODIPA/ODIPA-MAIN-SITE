{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/board-application/layout,_N_T_/board-application/page,_N_T_/board-application/"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/board-application/__PAGE__",
    "/board-application",
    "/_index",
    "/_head"
  ]
}